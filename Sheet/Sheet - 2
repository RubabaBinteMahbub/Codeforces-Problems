for(int i=2; i<=n; i++){
  bool isPrime = true;
    for(int j=2; j*j<=i; j++){
    if(i%j == 0){
    isPrime = false;
    break;
    }
}
 
 if(isPrime) cout<<i<<" "; 
}
🟩 Palindrome Check.
long long n;
cin>>n;

string s;

s=to_string(n);
reverse(s.begin(), s.end());

long long np=stoll(s);

if(n==np){
cout<<np<<"\n";
cout<<"YES\n";
}
else{
cout<<np<<"\n";
cout<<"NO";
}
🟩 Lucky number 
🌼 s.find_first_not_of("47") কী করে?
👉 এটা string-এর মধ্যে প্রথম এমন character খুঁজে
যেটা "4" বা "7" না
যদি পায় → তার index return করে
না পেলে → string::npos return করে

