🟩 Print Divisors.
long long n;
cin>>n;

vector<long long>v;
for(long long i=1; i*i<=n; i++){
if(n%i==0){
 v.push_back(i);
 if(i!=n/i){
    v.push_back(n/i);
  }
}
}

sort(v.begin(), v.end());

for(long long i=0; i<v.size(); i++){
if(i != 0) cout<<" ";
cout<<v[i];
}
